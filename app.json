{
  "expo": {
    "name": "데프스피릿 FC",
    "slug": "futsal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/defe-spirit-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "futsal-app",
    "splash": {
      "image": "./assets/defe-spirit-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/defe-spirit-logo.png",
        "backgroundColor": "#F9FAFB"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yrnoh.futsalapp"
    },
    "web": {
      "favicon": "./assets/defe-spirit-logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/defe-spirit-logo.png",
          "color": "#3182F6"
        }
      ],
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Pretendard-Regular.otf",
            "./assets/fonts/Pretendard-Medium.otf",
            "./assets/fonts/Pretendard-SemiBold.otf",
            "./assets/fonts/Pretendard-Bold.otf",
            "./assets/fonts/Pretendard-ExtraBold.otf"
          ]
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1459bf7d-d57e-417a-9fce-986ac351f50b"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1459bf7d-d57e-417a-9fce-986ac351f50b"
      }
    }
  }
}
